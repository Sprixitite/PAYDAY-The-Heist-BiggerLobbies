				<param type="string" /> <!-- Peer Name -->
				<param type="string" /> <!-- Mask set -->
				<param type="string" /> <!-- Dlcs "dlc1 dlc2" -->
				<param type="string" /> <!-- clients external IP as supplied by matchmaking server -->
				<param type="string" /> <!-- Steam User ID -->
				<param type="string" /> <!-- Host Steam User ID (used for pc only) -->
			</message>
			
