	<tweak version="2.0" name="settings/network" extension="network_settings"> <!-- join_request_reply -->
		<search>
			<network/>
			<rpc/>
			<message name="join_request_reply" delivery="ordered" receiver="connection"/>
		</search>

		<target mode="replace">
			<message name="join_request_reply" delivery="ordered" receiver="connection">	
				<param type="int" min="0" max="4" /> <!-- Reply info 0 == may not join, 1 == ok, 2 == kicked, 3 == game started, 4 = map not owned -->
				<param type="int" min="0" max="15" /> <!-- Peer id ~=0 when accepted -->
				<param type="int" min="1" max="16" /> <!-- level index -->
				<param type="int" min="1" max="5" /> <!-- difficulty index -->
				<param type="int" min="0" max="4" /> <!-- Game State ~=0 when accepted, lobby, in game etc -->
				<param type="string" /> <!-- Mask set -->
				<param type="string" /> <!-- Steam User ID (used for pc only) -->
			</message>
		</target>
	</tweak>

