<?xml version="1.0"?>
<tweaks>
	<tweak version="2.0" name="settings/network" extension="network_settings"> <!-- remove_dead_peer -->
		<search>
			<network/>
			<rpc/>
			<message name="remove_dead_peer" delivery="ordered" receiver="connection" check="server_to_client"/>
			<param type="int" min="1" max="4" />
		</search>

		<target mode="replace">
			<param type="int" min="1" max="15" />
		</target>
	</tweak>

